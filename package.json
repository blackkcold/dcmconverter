{
  "name": "local-dicom-jpeg-tool",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Local-first browser tool for viewing DICOM files and exporting non-diagnostic JPEG images with burned-in key metadata.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "quality": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@cornerstonejs/core": "^5.0.8",
    "@cornerstonejs/dicom-image-loader": "^5.0.8",
    "@cornerstonejs/tools": "^5.0.8",
    "dicom-parser": "^1.8.21",
    "fflate": "^0.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^4.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "jsdom": "^27.0.0",
    "playwright": "^1.60.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
